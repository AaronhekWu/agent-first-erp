node_modules
.next
out
.env.local
.env.*.local
*.tsbuildinfo
next-env.d.ts

# --- 本地遗留资产 (保留在磁盘, 不上 git) ---
# 前缀 / 表示"只匹配仓库根"; 不加 / 会匹配任意层级 (例如 supabase/ 会误吃 lib/supabase/)
# 旧 Django 后端 (业务逻辑已全迁到 Supabase RPC + Edge Function)
/apps/
/config/
/manage.py
/pyproject.toml
/requirements/
/.env.example

# DB 迁移 SQL / Edge Function 源码 / 项目文档 / MCP 配置
# (都已 apply 到生产 Supabase / 或仅本机/AI 用)
/migrations/
# supabase/ 下默认忽略, 但纳管 migrations/ (版本化 DB 变更, 与生产同步)
/supabase/*
!/supabase/migrations/
/docs/
/.mcp.json
/.codex/config.toml

